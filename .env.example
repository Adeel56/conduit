# Copy to .env and fill in real values: `cp .env.example .env`
# .env is git-ignored (see .gitignore); only this template is committed. Never commit secrets.

# --- Postgres (docker-compose) ---
POSTGRES_DB=conduit
POSTGRES_USER=conduit
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432

# --- Redis (stub for later: rate limiting + delivery queue) ---
REDIS_PORT=6379

# --- App ---
SERVER_PORT=8080

# --- Spring datasource ---
# Used when running the app OUTSIDE compose (e.g. `./mvnw spring-boot:run` against the
# compose Postgres). Inside compose the app service derives these from POSTGRES_* automatically.
# If you set them here, SPRING_DATASOURCE_PASSWORD must match POSTGRES_PASSWORD above.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/conduit
SPRING_DATASOURCE_USERNAME=conduit
SPRING_DATASOURCE_PASSWORD=change-me-locally
